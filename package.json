{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck",
    "build:frontend": "pnpm --filter @workspace/snackveda run build",
    "dev:frontend": "pnpm --filter @workspace/snackveda run dev",
    "dev:api": "pnpm --filter @workspace/api-server run dev"
  },
  "private": true,
  "devDependencies": {
    "prettier": "^3.8.1",
    "tsx": "catalog:",
    "typescript": "~5.9.2"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "drizzle-orm": "^0.45.2",
    "jsonwebtoken": "^9.0.2",
    "zod": "^3.25.76",
    "postgres": "^3.4.5"
  },
  "packageManager": "pnpm@10.33.0"
}
